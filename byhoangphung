-- 3. HỆ THỐNG HIGHLIGHT ESP XUYÊN TƯỜNG (DƯỚI 600M) & AIMBOT MƯỢT
-- ====================================================================
local function MobileFire(state)
    local center = Vector3.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2, 0)
    local touchObject = Instance.new("InputObject")
    pcall(function()
        local raw = getmetatable(touchObject)
        if raw then
            raw.UserInputType = Enum.UserInputType.Touch
            raw.UserInputState = state
            raw.Position = center
        end
    end)
    UserInputService.InputBegan:Fire(touchObject, false)
end

local function IsBehindWall(targetPart, targetCharacter)
    if not targetPart or not targetPart:IsDescendantOf(workspace) or not targetCharacter then return true end
    local myChar = LocalPlayer.Character
    if not myChar then return true end

    local origin = Camera.CFrame.Position
    local direction = targetPart.Position - origin

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {myChar, gui, workspace:FindFirstChild("ViewModel")}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true

    local success, raycastResult = pcall(function()
        return workspace:Raycast(origin, direction, raycastParams)
    end)

    if success and raycastResult then
        local hit = raycastResult.Instance
        if hit and not hit:IsDescendantOf(targetCharacter) then
            if hit.CanCollide == true and hit.Transparency < 0.7 then return true end
        end
    end
    return false 
end

RunService.RenderStepped:Connect(function()
    local myChar = LocalPlayer.Character
    local Viewport = Camera.ViewportSize
    local center = Vector2.new(Viewport.X / 2, Viewport.Y / 2)  
    local aimTarget = nil
    local shortestDistance = math.huge  

    Circle.Position = center
    Circle.Visible = AIMBOT

    for _, p in pairs(Players:GetPlayers()) do  
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            local hitPart = char:FindFirstChild("HitboxHead") or char:FindFirstChild("HitboxBody") or char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head") or char.PrimaryPart
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            
            local isAlive = false
            if humanoid then isAlive = humanoid.Health > 0
            elseif hitPart then isAlive = hitPart:IsDescendantOf(workspace) end
            
            local currentDistance = hitPart and (Camera.CFrame.Position - hitPart.Position).Magnitude or math.huge
            
            -- --- ĐỔI SANG HIGHLIGHT ESP SIÊU ĐẸP, MƯỢT, KHÔNG LỖI BOX ---
            if ESP and isAlive and currentDistance <= MAX_ESP_DISTANCE then
                if not CacheHighlight[p] then
                    local hl = Instance.new("Highlight")
                    hl.Name = "ESP_Highlight_" .. p.Name
                    hl.FillColor = Color3.fromRGB(255, 50, 50)
                    hl.FillTransparency = 0.6 -- Độ đậm nhạt màu thân người
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255) -- Viền trắng phát sáng ngoài
                    hl.OutlineTransparency = 0.1
                    hl.Adornee = char
                    hl.Parent = gui -- Để an toàn, quản lý tập trung tại Gui
                    CacheHighlight[p] = hl
                else
                    -- Luôn gán lại Adornee phòng trường hợp địch hồi sinh đổi model
                    CacheHighlight[p].Adornee = char
                    CacheHighlight[p].Enabled = true
                end
            else
                if CacheHighlight[p] then
                    CacheHighlight[p].Enabled = false
                end
            end
            
            -- --- LOCK DUY NHẤT PLAYER CHỐNG GIẬT ---
            if AIMBOT and hitPart and isAlive and myChar then
                local pos, visibleOnScreen = false, false
                pcall(function() pos, visibleOnScreen = Camera:WorldToViewportPoint(hitPart.Position) end)

                if visibleOnScreen and pos then  
                    local pixelDistance = (Vector2.new(pos.X, pos.Y) - center).Magnitude  
                    if pixelDistance < Circle.Radius and pixelDistance < shortestDistance then  
                        if not IsBehindWall(hitPart, char) then
                            shortestDistance = pixelDistance  
                            aimTarget = hitPart  
                        end
                    end
                end  
            end
        else
            ClearPlayerHighlight(p)
        end  
    end  

    -- --- CƠ CHẾ AIM CHỐNG GIẬT CAMERA MƯỢT 100% ---
    if AIMBOT and aimTarget and aimTarget:IsDescendantOf(workspace) then  
        pcall(function()
            local camCFrame = Camera.CFrame
            local targetPos = aimTarget.Position
            local lookAtTarget = CFrame.lookAt(camCFrame.Position, targetPos)
            
            -- Đồng bộ dạng xoay (Rotation) triệt tiêu độ rung giật màn hình
            Camera.CFrame = CFrame.new(camCFrame.Position) * lookAtTarget.Rotation
        end)
        
        if not IS_SHOOTING then
            IS_SHOOTING = true
            MobileFire(Enum.UserInputState.Begin)
        end
    else
        if IS_SHOOTING then
            IS_SHOOTING = false
            MobileFire(Enum.UserInputState.End)
        end
    end
end)

