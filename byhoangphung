-- --- HỆ THỐNG ÂM THANH (POP / PIP) MƯỢT MÀ ---
local function PlaySound(soundType)
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://12221967" -- Sử dụng âm thanh click cơ bản hệ thống
    sound.Volume = 0.5
    
    if soundType == "pop" then
        sound.PlaybackSpeed = 1.2 -- Tiếng Pop trầm, nảy khi bấm nút chức năng
    elseif soundType == "pip" then
        sound.PlaybackSpeed = 2.0 -- Tiếng Pip thanh, cao khi thu gọn menu
    end
    
    sound.Parent = game:GetService("SoundService")
    sound:Play()
    sound.Ended:Connect(function() sound:Destroy() end)
end

